<!DOCTYPE html>
<html lang="vi">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Rosabelle Tea</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;500;600;700&family=Great+Vibes&display=swap"
          rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- CSS -->

    @RenderSection("Styles", required: false)

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #fffaf8;
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }

        /* =========================
           HEADER
        ========================== */

        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 9999;
            padding: 18px 0;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(14px);
            transition: 0.35s ease;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

            .header.scrolled {
                background: rgba(255,255,255,0.92);
                box-shadow: 0 8px 30px rgba(0,0,0,0.05);
            }

                .header.scrolled .nav-link-custom,
                .header.scrolled .header-icon,
                .header.scrolled .logo-middle {
                    color: #5d4c54 !important;
                }

        .header-wrapper {
            width: 95%;
            max-width: 1450px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 30px;
        }

        /* =========================
           LOGO
        ========================== */

        .logo-link {
            text-decoration: none;
        }

        .logo-middle {
            font-family: 'Great Vibes', cursive;
            font-size: 42px;
            color: white;
            white-space: nowrap;
            transition: 0.3s;
        }

            .logo-middle:hover {
                color: #f3c4d1 !important;
            }

        /* =========================
           SEARCH
        ========================== */

        .search-wrapper {
            flex: 1;
            max-width: 350px;
        }

        .search-form {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.15);
            border-radius: 999px;
            overflow: hidden;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.15);
        }

        .search-input {
            flex: 1;
            border: none;
            background: transparent;
            padding: 12px 18px;
            color: white;
            outline: none;
            font-size: 14px;
        }

            .search-input::placeholder {
                color: rgba(255,255,255,0.8);
            }

        .header.scrolled .search-input {
            color: #5d4c54;
        }

            .header.scrolled .search-input::placeholder {
                color: #888;
            }

        .search-btn {
            width: 50px;
            height: 46px;
            border: none;
            background: transparent;
            color: white;
        }

        .header.scrolled .search-btn {
            color: #5d4c54;
        }

        /* =========================
           MENU
        ========================== */

        .menu-header {
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
        }

        .nav-menu {
            display: flex;
            align-items: center;
            gap: 10px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

            .nav-menu li {
                position: relative;
            }

        .nav-link-custom {
            text-decoration: none;
            color: white;
            font-size: 15px;
            font-weight: 500;
            padding: 12px 18px;
            border-radius: 999px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .nav-link-custom:hover {
                background: rgba(255,255,255,0.15);
                color: #f3c4d1 !important;
            }

        /* =========================
           SUBMENU
        ========================== */

        .submenu {
            position: absolute;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            min-width: 900px;
            border-radius: 30px;
            padding: 35px;
            display: flex;
            gap: 40px;
            opacity: 0;
            visibility: hidden;
            transition: 0.35s;
            box-shadow: 0 25px 60px rgba(0,0,0,0.08);
        }

        .menu-item:hover .submenu {
            opacity: 1;
            visibility: visible;
            top: 60px;
        }

        .submenu-column h4 {
            font-size: 17px;
            color: #5d4c54;
            margin-bottom: 18px;
            font-weight: 700;
        }

        .submenu-column a {
            color: #888;
            text-decoration: none;
            display: block;
            margin-bottom: 10px;
            transition: 0.3s;
        }

            .submenu-column a:hover {
                color: #d88ca0;
                transform: translateX(4px);
            }

        /* =========================
           RIGHT ICONS
        ========================== */

        .right-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header-icon {
            color: white;
            font-size: 20px;
            transition: 0.3s;
        }

            .header-icon:hover {
                color: #f3c4d1 !important;
            }

        /* =========================
           CART
        ========================== */

        .cart-item {
            position: relative;
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -12px;
            width: 22px;
            height: 22px;
            background: #f5935b;
            color: white;
            border-radius: 50%;
            font-size: 11px;
            font-weight: 700;
            display: none;
            align-items: center;
            justify-content: center;
        }

        /* =========================
           USER DROPDOWN
        ========================== */

        .dropdown-custom {
            position: relative;
        }

        .dropdown-toggle-custom {
            cursor: pointer;
        }

        .dropdown-menu-custom {
            position: absolute;
            top: 55px;
            right: 0;
            background: white;
            border-radius: 22px;
            min-width: 200px;
            padding: 15px;
            opacity: 0;
            visibility: hidden;
            transition: 0.3s;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .dropdown-custom:hover .dropdown-menu-custom {
            opacity: 1;
            visibility: visible;
            top: 48px;
        }

        .dropdown-menu-custom a {
            display: block;
            padding: 12px 15px;
            border-radius: 14px;
            color: #5d4c54;
            text-decoration: none;
            transition: 0.3s;
        }

            .dropdown-menu-custom a:hover {
                background: #fff1f5;
                color: #d88ca0;
            }

        .avatar-img {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            object-fit: cover;
        }

        /* =========================
           FOOTER
        ========================== */

        .footer {
            background: #201b1d;
            padding: 90px 0 30px;
            color: rgba(255,255,255,0.8);
        }

        .footer-container {
            width: 92%;
            max-width: 1400px;
            margin: auto;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 40px;
        }

        .footer-title {
            color: white;
            font-size: 20px;
            margin-bottom: 25px;
            font-weight: 600;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

            .footer-links li {
                margin-bottom: 14px;
            }

            .footer-links a {
                text-decoration: none;
                color: rgba(255,255,255,0.7);
                transition: 0.3s;
            }

                .footer-links a:hover {
                    color: #f3c4d1;
                }

        .footer-ad {
            background: white;
            border-radius: 28px;
            overflow: hidden;
        }

            .footer-ad img {
                width: 100%;
                height: 220px;
                object-fit: cover;
            }

        .footer-ad-content {
            padding: 22px;
        }

            .footer-ad-content h5 {
                color: #5d4c54;
                margin-bottom: 10px;
            }

            .footer-ad-content p {
                color: #888;
                margin-bottom: 10px;
            }

        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

            .social-icons a {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                transition: 0.3s;
                text-decoration: none;
            }

                .social-icons a:hover {
                    background: #f3c4d1;
                    color: #5d4c54;
                }

        .copyright {
            margin-top: 60px;
            border-top: 1px solid rgba(255,255,255,0.08);
            padding-top: 30px;
            text-align: center;
            line-height: 2;
            font-size: 14px;
        }

        /* =========================
           FLOAT BUTTONS
        ========================== */

        .scroll-buttons {
            position: fixed;
            right: 25px;
            bottom: 30px;
            z-index: 999;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

            .scroll-buttons button {
                width: 58px;
                height: 58px;
                border-radius: 50%;
                border: none;
                background: #f3c4d1;
                color: #5d4c54;
                font-size: 18px;
                box-shadow: 0 12px 30px rgba(243,196,209,0.4);
                transition: 0.3s;
            }

                .scroll-buttons button:hover {
                    transform: translateY(-5px);
                    background: #d88ca0;
                    color: white;
                }

        /* =========================
           RESPONSIVE
        ========================== */

        @@media(max-width: 1200px) {

            .header-wrapper {
                flex-wrap: wrap;
            }

            .submenu {
                min-width: 700px;
                flex-wrap: wrap;
            }

            .footer-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media(max-width: 768px) {

            .header {
                padding: 15px 0;
            }

            .header-wrapper {
                flex-direction: column;
                gap: 20px;
            }

            .logo-middle {
                font-size: 34px;
            }

            .search-wrapper {
                width: 100%;
                max-width: 100%;
            }

            .menu-header {
                width: 100%;
                overflow-x: auto;
                justify-content: flex-start;
            }

            .nav-menu {
                width: max-content;
            }

            .submenu {
                display: none !important;
            }

            .footer-grid {
                grid-template-columns: 1fr;
            }

            .scroll-buttons {
                right: 15px;
                bottom: 20px;
            }
        }
    </style>

</head>

<body>

    <!-- HEADER -->

    <header class="header" id="header">

        <div class="header-wrapper">

            <!-- LOGO -->

            <a href="@Url.Action("Home", "Home")"
               class="logo-link">

                <div class="logo-middle">
                    Rosabelle Tea
                </div>

            </a>

            <!-- SEARCH -->

            <div class="search-wrapper">

                <form action="@Url.Action("Search", "SanPham")"
                      method="get"
                      class="search-form">

                    <input type="text"
                           name="query"
                           class="search-input"
                           placeholder="Tìm kiếm sản phẩm..." />

                    <button type="submit"
                            class="search-btn">

                        <i class="fas fa-search"></i>

                    </button>

                </form>

            </div>

            <!-- MENU -->

            <nav class="menu-header">

                <ul class="nav-menu">

                    <li>
                        <a href="@Url.Action("Home", "Home")"
                           class="nav-link-custom">

                            Trang chủ

                        </a>
                    </li>

                    <li class="menu-item">

                        <a href="@Url.Action("SanPham", "SanPham")"
                           class="nav-link-custom">

                            Sản phẩm

                            <i class="fas fa-chevron-down"
                               style="font-size:12px;"></i>

                        </a>

                        <!-- SUBMENU -->

                        <div class="submenu">

                            <div class="submenu-column">
                                <h4>Tất cả</h4>
                                <a href="@Url.Action("SanPham", "SanPham")">
                                    Xem tất cả
                                </a>
                            </div>

                            <div class="submenu-column">
                                <h4>Cà phê</h4>
                                <a href="@Url.Action("SanPham", "SanPham", new { categoryId = 1 })">
                                    Cà phê
                                </a>
                            </div>

                            <div class="submenu-column">
                                <h4>Trà sữa</h4>
                                <a href="@Url.Action("SanPham", "SanPham", new { categoryId = 2 })">
                                    Trà sữa
                                </a>
                            </div>

                            <div class="submenu-column">
                                <h4>Đá xay</h4>
                                <a href="@Url.Action("SanPham", "SanPham", new { categoryId = 3 })">
                                    Đá xay
                                </a>
                            </div>

                            <div class="submenu-column">
                                <h4>Bánh & Snack</h4>
                                <a href="@Url.Action("SanPham", "SanPham", new { categoryId = 4 })">
                                    Bánh & Snack
                                </a>
                            </div>

                            <div class="submenu-column">
                                <h4>Trà trái cây</h4>
                                <a href="@Url.Action("SanPham", "SanPham", new { categoryId = 5 })">
                                    Trà trái cây
                                </a>
                            </div>

                        </div>

                    </li>

                    <li>
                        <a href="@Url.Action("Index", "GT")"
                           class="nav-link-custom">

                            Giới thiệu

                        </a>
                    </li>

                    <li>
                        <a href="@Url.Action("Index", "Lienhe")"
                           class="nav-link-custom">

                            Liên hệ

                        </a>
                    </li>

                    <li>
                        <a href="@Url.Action("Thethanhvien", "Thethanhvien")"
                           class="nav-link-custom">

                            Thẻ thành viên

                        </a>
                    </li>

                </ul>

            </nav>

            <!-- RIGHT -->

            <div class="right-actions">

                <!-- CART -->

                <div class="cart-item">

                    <a href="@Url.Action("GioHang", "GioHang")">

                        <i class="fas fa-shopping-bag header-icon"></i>

                        <span id="cart-count"
                              class="cart-count"></span>

                    </a>

                </div>

                <!-- USER -->

                <div class="dropdown-custom">

                    @if (Session["Username"] == null)
                    {
                        <div class="dropdown-toggle-custom">

                            <i class="fas fa-user header-icon"></i>

                        </div>

                        <div class="dropdown-menu-custom">

                            <a href="@Url.Action("Login", "Login")">
                                Đăng nhập
                            </a>

                            <a href="@Url.Action("Register", "Register")">
                                Đăng ký
                            </a>

                        </div>
                    }
                    else
                    {
                        <div class="dropdown-toggle-custom">

                            @if (!string.IsNullOrEmpty(Session["AvatarUrl"]?.ToString()))
                            {
                                <img src="@Session["AvatarUrl"]"
                                     alt="Avatar"
                                     class="avatar-img" />
                            }
                            else
                            {
                                <i class="fas fa-user header-icon"></i>
                            }

                        </div>

                        <div class="dropdown-menu-custom">

                            <a href="@Url.Action("TaiKhoan", "TaiKhoan")">
                                Tài khoản
                            </a>

                            <a href="@Url.Action("Logout", "Login")">
                                Đăng xuất
                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </header>

    <!-- MAIN -->

    <main class="main-content">

        @RenderBody()

    </main>

    <!-- FOOTER -->

    <footer class="footer">

        <div class="footer-container">

            <div class="footer-grid">

                <!-- ABOUT -->

                <div>

                    <h3 class="footer-title">
                        Giới thiệu
                    </h3>

                    <ul class="footer-links">

                        <li>
                            <a href="@Url.Action("Index", "GT")">
                                Về chúng tôi
                            </a>
                        </li>

                        <li>
                            <a href="@Url.Action("SanPham", "SanPham")">
                                Sản phẩm
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                Khuyến mãi
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                Cửa hàng
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- POLICY -->

                <div>

                    <h3 class="footer-title">
                        Điều khoản
                    </h3>

                    <ul class="footer-links">

                        <li>
                            <a href="#">
                                Điều khoản sử dụng
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                Chính sách bảo mật
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                Xuất hóa đơn
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- CONTACT -->

                <div>

                    <h3 class="footer-title">
                        Liên hệ
                    </h3>

                    <p style="line-height:2;">

                        Hotline:
                        1900 3013

                        <br />

                        hi@RosabelleTea.vn

                        <br />

                        Tân An, Long An

                    </p>

                </div>

                <!-- SOCIAL -->

                <div>

                    <div class="footer-ad">

                        <img src="@Url.Content("~/images/logo.png")"
                             alt="Rosabelle Tea">

                        <div class="footer-ad-content">

                            <h5>
                                Rosabelle Tea
                            </h5>

                            <p>
                                Sweet little happiness 💖
                            </p>

                        </div>

                    </div>

                    <div class="social-icons">

                        <a href="#">
                            <i class="fab fa-facebook-f"></i>
                        </a>

                        <a href="#">
                            <i class="fab fa-instagram"></i>
                        </a>

                        <a href="#">
                            <i class="fab fa-tiktok"></i>
                        </a>

                    </div>

                </div>

            </div>

            <!-- COPYRIGHT -->

            <div class="copyright">

                © 2014 - 2026 Rosabelle Tea.
                All Rights Reserved.

            </div>

        </div>

        <!-- FLOAT BUTTONS -->

        <div class="scroll-buttons">

            <button id="scrollToTop">
                <i class="fas fa-arrow-up"></i>
            </button>

            <button id="scrollToBottom">
                <i class="fas fa-arrow-down"></i>
            </button>

            <button>
                <i class="fas fa-headset"></i>
            </button>

        </div>

    </footer>

    <!-- JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        // HEADER SCROLL

        window.addEventListener("scroll", function () {

            const header = document.getElementById("header");

            if (window.scrollY > 50) {
                header.classList.add("scrolled");
            }
            else {
                header.classList.remove("scrolled");
            }
        });

        // SCROLL BUTTON

        document.getElementById("scrollToTop")
            .addEventListener("click", function () {

                window.scrollTo({
                    top: 0,
                    behavior: "smooth"
                });
            });

        document.getElementById("scrollToBottom")
            .addEventListener("click", function () {

                window.scrollTo({
                    top: document.body.scrollHeight,
                    behavior: "smooth"
                });
            });

        // UPDATE CART

        function updateCartCount(count) {

            var cartCountElement =
                document.getElementById("cart-count");

            if (cartCountElement) {

                cartCountElement.textContent =
                    count > 0 ? count : "";

                cartCountElement.style.display =
                    count > 0 ? "flex" : "none";
            }
        }

        // LOAD CART COUNT

        document.addEventListener("DOMContentLoaded", function () {

            fetch('/GioHang/GetCartCount', {

                method: 'GET',

                headers: {
                    'Content-Type': 'application/json'
                }

            })

                .then(response => response.json())

                .then(data => {

                    if (data.cartCount !== undefined) {

                        updateCartCount(data.cartCount);
                    }
                })

                .catch(error => {

                    console.error(error);
                });
        });

    </script>

    @RenderSection("scripts", required: false)

</body>
</html>