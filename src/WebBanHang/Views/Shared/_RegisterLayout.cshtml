<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Rosabelle Tea</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient( rgba(255,240,245,0.65), rgba(255,228,236,0.7) ), url('/images/nen6.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .container {
            width: 100%;
            max-width: 520px;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(12px);
            border-radius: 35px;
            overflow: hidden;
            box-shadow: 0 15px 45px rgba(216, 91, 127, 0.18);
            border: 1px solid rgba(255,255,255,0.4);
            position: relative;
        }

            .container::before {
                content: "";
                position: absolute;
                top: -80px;
                right: -80px;
                width: 180px;
                height: 180px;
                background: rgba(255, 143, 177, 0.18);
                border-radius: 50%;
            }

            .container::after {
                content: "";
                position: absolute;
                bottom: -70px;
                left: -70px;
                width: 160px;
                height: 160px;
                background: rgba(255, 192, 203, 0.15);
                border-radius: 50%;
            }

        .right {
            position: relative;
            z-index: 2;
            padding: 45px 40px;
        }

        h2 {
            text-align: center;
            color: #d85b7f;
            font-size: 38px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .subtitle {
            text-align: center;
            color: #8c8c8c;
            margin-bottom: 28px;
            font-size: 15px;
        }

        .input-group {
            position: relative;
            margin-bottom: 18px;
        }

            .input-group input {
                width: 100%;
                height: 54px;
                border-radius: 18px;
                border: 1px solid #f2c8d4;
                background: #fffafb;
                padding: 0 48px;
                font-size: 15px;
                transition: all 0.3s ease;
            }

                .input-group input:focus {
                    outline: none;
                    background: #fff;
                    border-color: #ff8fb1;
                    box-shadow: 0 0 0 4px rgba(255,143,177,0.15);
                }

                .input-group input.invalid {
                    border: 1px solid #e53935;
                }

            .input-group i:not(.toggle-password) {
                position: absolute;
                top: 50%;
                left: 16px;
                transform: translateY(-50%);
                color: #d694a7;
                font-size: 15px;
                pointer-events: none;
            }

        .toggle-password {
            position: absolute;
            top: 50%;
            right: 16px;
            transform: translateY(-50%);
            color: #c48a9b;
            cursor: pointer;
            transition: 0.2s ease;
        }

            .toggle-password:hover {
                color: #d85b7f;
            }

        .btn-register {
            width: 100%;
            height: 54px;
            border: none;
            border-radius: 35px;
            background: linear-gradient( 135deg, #ff8fb1, #d86b8f );
            color: white;
            font-size: 16px;
            font-weight: 600;
            margin-top: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(216,107,143,0.35);
            }

        .signin {
            text-align: center;
            margin-top: 22px;
            color: #777;
            font-size: 14px;
        }

            .signin a {
                color: #d85b7f;
                font-weight: 600;
                text-decoration: none;
            }

                .signin a:hover {
                    text-decoration: underline;
                }

        .or-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 24px 0;
        }

            .or-divider::before,
            .or-divider::after {
                content: "";
                flex: 1;
                height: 1px;
                background: #e6d9de;
            }

            .or-divider span {
                margin: 0 12px;
                color: #999;
                font-size: 14px;
                font-weight: 500;
            }

        .social-btn {
            width: 100%;
            height: 52px;
            border: none;
            border-radius: 16px;
            margin-bottom: 14px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s ease;
        }

            .social-btn i {
                margin-right: 10px;
            }

        .facebook {
            background: #1877f2;
            color: white;
        }

            .facebook:hover {
                background: #0f63d8;
            }

        .google {
            background: white;
            color: #444;
            border: 1px solid #ececec;
        }

            .google:hover {
                background: #f7f7f7;
            }

        .error {
            color: #e53935;
            text-align: center;
            margin-bottom: 14px;
            font-size: 14px;
        }

        .error-message {
            display: block;
            color: #e53935;
            font-size: 13px;
            margin-top: -8px;
            margin-bottom: 12px;
            padding-left: 5px;
        }

        @@media(max-width: 768px) {

            body {
                padding: 20px;
            }

            .container {
                max-width: 100%;
            }

            .right {
                padding: 35px 25px;
            }

            h2 {
                font-size: 32px;
            }
        }

        @@media(max-width: 480px) {

            .right {
                padding: 30px 20px;
            }

            h2 {
                font-size: 28px;
            }

            .input-group input {
                height: 50px;
            }

            .btn-register {
                height: 50px;
            }
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="right">

            @RenderBody()

        </div>

    </div>

    <script>

        function responsiveLayout() {

            const container = document.querySelector('.container');

            if (!container) return;

            if (window.innerWidth <= 768) {

                container.style.width = "100%";

            } else {

                container.style.width = "";
            }
        }

        window.addEventListener('resize', responsiveLayout);

        window.addEventListener('load', responsiveLayout);

    </script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>