@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO BANNER -->
<section class="banner">

    <div id="carouselBanner"
         class="carousel slide"
         data-bs-ride="carousel">

        <div class="carousel-inner">

            <!-- SLIDE 1 -->
            <div class="carousel-item active">

                <video autoplay muted loop class="d-block w-100 banner-video">
                    <source src="@Url.Content("~/video/vd6.mp4")" type="video/mp4" />
                </video>

                <div class="banner-overlay">
                    <h1>
                        Contact & Sweet Connections
                    </h1>

                    <p>
                        We’re always here to listen, support and share lovely moments with you 💖
                    </p>

                </div>

            </div>

            <!-- SLIDE 2 -->
            <div class="carousel-item">

                <video autoplay muted loop class="d-block w-100 banner-video">
                    <source src="@Url.Content("~/video/vd9.mp4")" type="video/mp4" />
                </video>

                <div class="banner-overlay">

                    <span class="mini-title">
                        Rosabelle Tea ✨
                    </span>

                    <h1>
                        Lovely Space For Lovely People
                    </h1>

                    <p>
                        Coffee • Tea • Cakes • Cute little happiness 🌸
                    </p>

                </div>

            </div>

        </div>

        <!-- CONTROLS -->
        <button class="carousel-control-prev"
                type="button"
                data-bs-target="#carouselBanner"
                data-bs-slide="prev">

            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>

        </button>

        <button class="carousel-control-next"
                type="button"
                data-bs-target="#carouselBanner"
                data-bs-slide="next">

            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>

        </button>

    </div>

</section>

<!-- CONTACT SECTION -->
<section class="contact-section">

    <div class="container">

        <div class="contact-header">

            <span>
                Rosabelle Tea ✨
            </span>

            <h2>
                Liên hệ với chúng tôi 💌
            </h2>

            <p>
                Nếu bạn có bất kỳ câu hỏi, góp ý hoặc muốn hợp tác cùng Rosabelle Tea,
                hãy gửi thông tin cho chúng tôi nhé 🌸
            </p>

        </div>

        <div class="contact-wrapper">

            <!-- LEFT -->
            <div class="contact-info-card">

                <div class="info-item">

                    <div class="info-icon">
                        📍
                    </div>

                    <div>

                        <h4>
                            Địa chỉ
                        </h4>

                        <p>
                            Trụ sở chính:
                            124 Hùng Vương, Phường 2,
                            Thành phố Tân An, Long An
                        </p>

                        <p>
                            Chi nhánh Bến Lức:
                            45 Nguyễn Hữu Trí,
                            Thị trấn Bến Lức, Long An
                        </p>

                        <p>
                            Chi nhánh Đức Hòa:
                            KCN Tân Đức,
                            Đức Hòa Hạ, Long An
                        </p>

                    </div>

                </div>

                <div class="info-item">

                    <div class="info-icon">
                        ☎️
                    </div>

                    <div>

                        <h4>
                            Hotline
                        </h4>

                        <p>
                            1900 3013
                        </p>

                    </div>

                </div>

                <div class="info-item">

                    <div class="info-icon">
                        ✉️
                    </div>

                    <div>

                        <h4>
                            Email
                        </h4>

                        <p>
                            hi@RosabelleTea.vn
                        </p>

                    </div>

                </div>

                <div class="contact-note">

                    <h3>
                        Sweet Message 🌷
                    </h3>

                    <p>
                        Rosabelle Tea luôn mong muốn mang đến cho bạn
                        không chỉ là một ly nước ngon,
                        mà còn là những khoảnh khắc dịu dàng và đáng nhớ 💖
                    </p>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="contact-form-card">

                <span class="mini-form-title">
                    Send us a message ✨
                </span>

                <h3>
                    Chúng tôi sẽ phản hồi sớm nhất 💕
                </h3>

                <form>

                    <div class="form-group">

                        <input type="text"
                               placeholder="Họ và tên*"
                               required />

                    </div>

                    <div class="form-group">

                        <input type="email"
                               placeholder="Email*"
                               required />

                    </div>

                    <div class="form-group">

                        <input type="text"
                               placeholder="Số điện thoại" />

                    </div>

                    <div class="form-group">

                        <textarea placeholder="Nội dung tin nhắn..."
                                  required></textarea>

                    </div>

                    <button type="submit" class="submit-btn">

                        Gửi liên hệ 💌

                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

<style>

    body {
        background: #fffaf8;
        font-family: 'Poppins', sans-serif;
    }

    /* BANNER */

    .banner {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .banner-video {
        width: 100%;
        height: 700px;
        object-fit: cover;
        filter: brightness(0.65);
    }

    .banner-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        width: 90%;
        color: white;
    }

    .mini-title {
        letter-spacing: 4px;
        text-transform: uppercase;
        font-size: 14px;
        color: #ffdce6;
    }

    .banner-overlay h1 {
        font-size: 72px;
        margin: 25px 0;
        font-weight: 700;
        color:white;
    }

    .banner-overlay p {
        font-size: 20px;
        max-width: 800px;
        margin: auto;
        line-height: 1.8;
        color: white;
    }

    /* CONTACT */

    .contact-section {
        padding-bottom: 100px;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 70px;
    }

        .contact-header span {
            color: #d9a5b3;
            text-transform: uppercase;
            letter-spacing: 4px;
            font-size: 13px;
        }

        .contact-header h2 {
            font-size: 52px;
            color: #5d4c54;
            margin: 20px 0;
            font-weight: 700;
        }

        .contact-header p {
            color: #888;
            max-width: 850px;
            margin: auto;
            line-height: 2;
            font-size: 17px;
        }

    .contact-wrapper {
        display: flex;
        gap: 40px;
        align-items: stretch;
    }

    /* LEFT */

    .contact-info-card {
        flex: 1;
        background: white;
        border-radius: 35px;
        padding: 45px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

    .info-item {
        display: flex;
        gap: 20px;
        margin-bottom: 40px;
    }

    .info-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #fff1f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .info-item h4 {
        color: #5d4c54;
        margin-bottom: 12px;
        font-size: 22px;
        font-weight: 600;
    }

    .info-item p {
        color: #777;
        line-height: 1.9;
        margin-bottom: 8px;
    }

    .contact-note {
        margin-top: 50px;
        background: #fff6f8;
        border-radius: 25px;
        padding: 30px;
    }

        .contact-note h3 {
            color: #d88ca0;
            margin-bottom: 15px;
            font-size: 28px;
            font-weight: 700;
        }

        .contact-note p {
            color: #777;
            line-height: 2;
        }

    /* FORM */

    .contact-form-card {
        flex: 1;
        background: white;
        border-radius: 35px;
        padding: 45px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

    .mini-form-title {
        color: #d9a5b3;
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: 13px;
    }

    .contact-form-card h3 {
        font-size: 38px;
        color: #5d4c54;
        margin: 20px 0 40px;
        font-weight: 700;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group input,
        .form-group textarea {
            width: 100%;
            border: none;
            background: #fff7f9;
            border-radius: 20px;
            padding: 18px 22px;
            font-size: 16px;
            color: #666;
        }

        .form-group textarea {
            height: 160px;
            resize: none;
        }

            .form-group input:focus,
            .form-group textarea:focus {
                outline: none;
                box-shadow: 0 0 0 4px rgba(243,196,209,0.25);
            }

    .submit-btn {
        width: 100%;
        border: none;
        padding: 18px;
        border-radius: 999px;
        background: linear-gradient(90deg, #f3c4d1, #eab3c3);
        color: #6a4d56;
        font-size: 17px;
        font-weight: 700;
        transition: 0.3s;
    }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(243,196,209,0.4);
        }

    /* RESPONSIVE */

    @@media(max-width: 1200px) {

        .contact-wrapper {
            flex-direction: column;
        }
    }

    @@media(max-width: 768px) {

        .banner-video {
            height: 500px;
        }

        .banner-overlay h1 {
            font-size: 42px;
        }

        .banner-overlay p {
            font-size: 16px;
        }

        .contact-header h2 {
            font-size: 36px;
        }

        .contact-form-card h3 {
            font-size: 30px;
        }

        .contact-info-card,
        .contact-form-card {
            padding: 30px;
        }
    }
</style>