@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="banner">

    <div id="carouselBanner"
         class="carousel slide"
         data-bs-ride="carousel">

        <div class="carousel-inner">

            <!-- VIDEO 1 -->
            <div class="carousel-item active">

                <video autoplay muted loop class="d-block w-100 banner-video">

                    <source src="@Url.Content("~/video/vd6.mp4")"
                            type="video/mp4" />

                </video>

                <div class="banner-overlay">

                    <span class="banner-mini-title">
                        Rosabelle Tea ✨
                    </span>

                    <h1>
                        Membership & Lovely Rewards
                    </h1>

                    <p>
                        Enjoy sweet moments, collect points,
                        unlock beautiful member privileges 💖
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- TERMS SECTION -->

<section class="terms-section">

    <div class="container">

        <div class="terms-wrapper">

            <!-- HEADER -->
            <div class="terms-header">
                <h1>
                    Điều khoản & Điều kiện thành viên 🌸
                </h1>

                <p>
                    Chính sách sử dụng chương trình thành viên
                    Rosabelle Tea dành cho khách hàng thân thiết.
                </p>

            </div>

            <!-- CONTENT -->
            <div class="terms-content">

                <div class="warning-box">

                    <strong>
                        VUI LÒNG ĐỌC KỸ NHỮNG ĐIỀU KHOẢN & ĐIỀU KIỆN SỬ DỤNG.
                    </strong>

                    <p>
                        Khi tham gia chương trình thành viên Rosabelle Tea,
                        bạn đồng ý với tất cả điều khoản và chính sách
                        được áp dụng bởi hệ thống.
                    </p>

                </div>

                <!-- SECTION 1 -->
                <div class="terms-block">

                    <h2>
                        1. Thông tin chung
                    </h2>

                    <p>
                        Chương trình thành viên Rosabelle Tea được tạo ra
                        nhằm tri ân khách hàng thân thiết và mang lại
                        nhiều ưu đãi hấp dẫn khi mua sắm tại hệ thống.
                    </p>

                    <p>
                        Rosabelle Tea có quyền thay đổi, cập nhật hoặc
                        điều chỉnh chính sách bất kỳ lúc nào mà không
                        cần thông báo trước.
                    </p>

                </div>

                <!-- SECTION 2 -->
                <div class="terms-block">

                    <h2>
                        2. Cách tham gia thành viên
                    </h2>

                    <div class="step-list">

                        <div class="step-item">

                            <div class="step-number">
                                1
                            </div>

                            <div class="step-content">

                                <h4>
                                    Tải ứng dụng
                                </h4>

                                <p>
                                    Tải ứng dụng Rosabelle Tea trên iOS
                                    hoặc Android.
                                </p>

                            </div>

                        </div>

                        <div class="step-item">

                            <div class="step-number">
                                2
                            </div>

                            <div class="step-content">

                                <h4>
                                    Đăng ký tài khoản
                                </h4>

                                <p>
                                    Đăng ký bằng số điện thoại và email cá nhân.
                                </p>

                            </div>

                        </div>

                        <div class="step-item">

                            <div class="step-number">
                                3
                            </div>

                            <div class="step-content">

                                <h4>
                                    Bắt đầu tích điểm
                                </h4>

                                <p>
                                    Tích lũy điểm và nhận ưu đãi thành viên.
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- SECTION 3 -->
                <div class="terms-block">

                    <h2>
                        3. Chính sách tích điểm
                    </h2>

                    <div class="highlight-card">

                        <h3>
                            🌸 1 Nốt nhạc = 20.000 VNĐ
                        </h3>

                        <p>
                            Điểm tích lũy được quy đổi dựa trên giá trị
                            hóa đơn mua hàng tại cửa hàng.
                        </p>

                    </div>

                    <ul class="custom-list">

                        <li>
                            Điểm không có thời hạn sử dụng.
                        </li>

                        <li>
                            Tích điểm khi mua trực tiếp tại cửa hàng.
                        </li>

                        <li>
                            Không áp dụng cho ứng dụng giao hàng bên thứ ba.
                        </li>

                        <li>
                            Voucher không quy đổi thành tiền mặt.
                        </li>

                    </ul>

                </div>

                <!-- SECTION 4 -->
                <div class="terms-block">

                    <h2>
                        4. Hạng thành viên
                    </h2>

                    <div class="member-grid">

                        <div class="member-card">

                            <span>
                                E-Member
                            </span>

                            <h3>
                                Thành viên mới
                            </h3>

                            <p>
                                Dành cho khách hàng vừa đăng ký.
                            </p>

                        </div>

                        <div class="member-card">

                            <span>
                                Fa
                            </span>

                            <h3>
                                200.000 VNĐ+
                            </h3>

                            <p>
                                Nhận ưu đãi sinh nhật & voucher.
                            </p>

                        </div>

                        <div class="member-card">

                            <span>
                                Sol
                            </span>

                            <h3>
                                3.000.000 VNĐ+
                            </h3>

                            <p>
                                Giảm giá 5% trên hóa đơn.
                            </p>

                        </div>

                        <div class="member-card">

                            <span>
                                La
                            </span>

                            <h3>
                                8.000.000 VNĐ+
                            </h3>

                            <p>
                                Giảm giá 10% trên hóa đơn.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- SECTION 5 -->
                <div class="terms-block">

                    <h2>
                        5. Quy định khác
                    </h2>

                    <ul class="custom-list">

                        <li>
                            Điểm tích lũy không có giá trị quy đổi tiền mặt.
                        </li>

                        <li>
                            Tài khoản không được chuyển nhượng.
                        </li>

                        <li>
                            Rosabelle Tea có quyền khóa tài khoản vi phạm.
                        </li>

                        <li>
                            Chính sách có thể thay đổi bất kỳ lúc nào.
                        </li>

                    </ul>

                </div>

            </div>

        </div>

    </div>

</section>

<style>

    body {
        background: #fffaf8;
        font-family: 'Poppins', sans-serif;
    }

    /* BANNER */

    .banner {
        position: relative;
    }

    .banner-video {
        height: 600px;
        object-fit: cover;
        filter: brightness(0.65);
    }

    .banner-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: white;
        width: 90%;
    }

    .banner-mini-title {
        display: inline-block;
        letter-spacing: 4px;
        text-transform: uppercase;
        font-size: 13px;
        margin-bottom: 20px;
        color: #ffdce6;
    }

    .banner-overlay h1 {
        font-size: 68px;
        font-weight: 700;
        margin-bottom: 25px;
        color:white;
    }

    .banner-overlay p {
        font-size: 20px;
        color: rgba(255,255,255,0.9);
        max-width: 800px;
        margin: auto;
        line-height: 1.8;
        color: white;
    }

    /* SECTION */

    .terms-section {
        padding-bottom: 100px;
    }

    .terms-wrapper {
        max-width: 1100px;
        margin: auto;
    }

    /* HEADER */

    .terms-header {
        text-align: center;
        margin-bottom: 60px;
    }

        .terms-header span {
            color: #d9a5b3;
            text-transform: uppercase;
            letter-spacing: 4px;
            font-size: 13px;
        }

        .terms-header h1 {
            color: #5d4c54;
            font-size: 52px;
            margin: 25px 0;
            font-weight: 700;
        }

        .terms-header p {
            color: #888;
            font-size: 18px;
            max-width: 800px;
            margin: auto;
            line-height: 1.9;
        }

    /* CONTENT */

    .terms-content {
        background: white;
        border-radius: 40px;
        padding: 60px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.05);
    }

    .terms-date {
        color: #999;
        margin-bottom: 30px;
        font-size: 15px;
    }

    .warning-box {
        background: #fff1f5;
        border-left: 5px solid #f3c4d1;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 50px;
    }

        .warning-box strong {
            color: #5d4c54;
            display: block;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .warning-box p {
            color: #777;
            line-height: 1.9;
            margin: 0;
        }

    /* BLOCK */

    .terms-block {
        margin-bottom: 70px;
    }

        .terms-block:last-child {
            margin-bottom: 0;
        }

        .terms-block h2 {
            color: #5d4c54;
            font-size: 34px;
            margin-bottom: 25px;
            font-weight: 700;
        }

        .terms-block p {
            color: #777;
            line-height: 2;
            font-size: 16px;
        }

    /* STEP */

    .step-list {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .step-item {
        display: flex;
        gap: 25px;
        align-items: flex-start;
        background: #fffafc;
        padding: 25px;
        border-radius: 25px;
    }

    .step-number {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #f3c4d1;
        color: #6a4d56;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 22px;
        flex-shrink: 0;
    }

    .step-content h4 {
        color: #5d4c54;
        margin-bottom: 10px;
        font-size: 22px;
    }

    .step-content p {
        margin: 0;
    }

    /* HIGHLIGHT */

    .highlight-card {
        background: linear-gradient(135deg, #fff1f5, #ffe6ef);
        padding: 35px;
        border-radius: 30px;
        margin-bottom: 30px;
    }

        .highlight-card h3 {
            color: #d88ca0;
            font-size: 34px;
            margin-bottom: 15px;
            font-weight: 700;
        }

    /* LIST */

    .custom-list {
        padding-left: 20px;
    }

        .custom-list li {
            margin-bottom: 16px;
            color: #666;
            line-height: 1.8;
        }

    /* MEMBER */

    .member-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .member-card {
        background: #fffafc;
        border-radius: 30px;
        padding: 35px 25px;
        text-align: center;
        transition: 0.3s;
    }

        .member-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.05);
        }

        .member-card span {
            color: #d9a5b3;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-size: 12px;
        }

        .member-card h3 {
            color: #5d4c54;
            margin: 18px 0;
            font-size: 26px;
            font-weight: 700;
        }

        .member-card p {
            color: #777;
            line-height: 1.8;
            margin: 0;
        }

    /* RESPONSIVE */

    @@media(max-width: 1200px) {

        .member-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 768px) {

        .banner-overlay h1 {
            font-size: 42px;
        }

        .banner-overlay p {
            font-size: 16px;
        }

        .terms-content {
            padding: 35px;
        }

        .terms-header h1,
        .terms-block h2 {
            font-size: 32px;
        }

        .member-grid {
            grid-template-columns: 1fr;
        }

        .step-item {
            flex-direction: column;
        }
    }
</style>