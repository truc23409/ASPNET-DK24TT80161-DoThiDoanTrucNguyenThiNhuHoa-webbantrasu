@{
    Layout = "../Shared/_Layout.cshtml";
}

<meta charset="utf-8">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="page-container">
    <div class="order-container">
        <!-- CỘT TRÁI: Danh sách bàn -->
        <div class="left-panel">
            <div class="tab-content dung-tai-ban active">
                <div id="tableListContainer">
                    @Html.Action("DanhSachBan", "DonHangOffline", new { area = "Admin" })
                </div>
                <div class="actions mt-2">
                    <button class="btn btn-primary btn-add-table">Thêm bàn</button>
                    <button class="btn btn-danger btn-remove-table">Xóa bàn</button>
                    <button class="btn btn-warning btn-return-table">Trả bàn</button>
                </div>
            </div>
        </div>

        <div class="right-panel">
            <!-- Load dropdown chọn loại + chọn món -->
            @Html.Action("DanhSachLoaiSanPham", "DonHangOffline", new { area = "Admin" })

            <!-- Khu vực chọn món -->
            <div id="productSection" class="mt-3"></div>

            <!-- Khu vực hóa đơn -->
            <div class="bill-section mt-4">
                <h5>Hóa đơn hiện tại</h5>
                <div id="invoiceContainer"></div>
                <button class="btn btn-success btn-pay mt-3">Thanh toán hóa đơn</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        const urlThemBan = '@Url.Action("ThemBan", "DonHangOffline", new { area = "Admin" })';
        const urlXoaBan = '@Url.Action("XoaBan", "DonHangOffline", new { area = "Admin" })';
        const urlDanhSachBan = '@Url.Action("DanhSachBan", "DonHangOffline", new { area = "Admin" })';
        const urlDanhSachSanPham = '@Url.Action("DanhSachSanPham", "DonHangOffline", new { area = "Admin" })';
        const urlGetInvoice = '@Url.Action("GetInvoicesByTableId", "DonHangOffline", new { area = "Admin" })';
        const urlThanhToan = '@Url.Action("ThanhToan", "DonHangOffline", new { area = "Admin" })';
        let selectedTableId = null;

        $(document).on('change', '#categorySelect', function () {
            const categoryId = $(this).val();
            if (categoryId) {
                $.getJSON('@Url.Action("GetFoodByCategory", "DonHangOffline", new { area = "Admin" })', { categoryId: categoryId }, function (data) {
                    let html = '';
                    data.forEach(item => {
                        html += `
                            <div class="food-item border p-2 mb-2 rounded shadow-sm">
                                <strong>${item.FoodName}</strong> - <span>${item.Price.toLocaleString('vi-VN')} đ</span>
                            </div>`;
                    });
                    $("#productSection").html(html);
                });
            } else {
                $("#productSection").html('');
            }
        });

        $(document).on('click', '.btn-add-table', function () {
            $.post(urlThemBan, {}, function (res) {
                if (res.success) {
                    $("#tableListContainer").load(urlDanhSachBan);
                } else {
                    alert('Lỗi khi thêm bàn');
                }
            });
        });

        $(document).on('click', '.btn-remove-table', function () {
            $.post(urlXoaBan, {}, function (res) {
                if (res.success) {
                    $("#tableListContainer").load(urlDanhSachBan);
                } else {
                    alert('Không còn bàn để xóa!');
                }
            });
        });

        $(document).on('click', '.table-item', function () {
            $('.table-item').removeClass('selected');
            $(this).addClass('selected');
            selectedTableId = $(this).data('id');

            // Load hóa đơn của bàn này
            $("#invoiceContainer").load(urlGetInvoice + '?tableId=' + selectedTableId);
        });

        $('.btn-pay').click(function () {
            if (!selectedTableId) {
                alert('Vui lòng chọn bàn để thanh toán!');
                return;
            }

            $.post(urlThanhToan, { tableId: selectedTableId }, function (res) {
                if (res.success) {
                    alert('Thanh toán thành công!');
                    $("#invoiceContainer").html('');
                    selectedTableId = null;
                    $("#tableListContainer").load(urlDanhSachBan);
                } else {
                    alert(res.message);
                }
            });
        });

        $(document).on('click', '.btn-return-table', function () {
            if (!selectedTableId) {
                alert('Vui lòng chọn bàn để trả!');
                return;
            }

            let $table = $('.table-item[data-id="' + selectedTableId + '"]');
            $table.removeClass('btn-warning btn-danger selected').addClass('btn-success');
            $table.find('.status-text').text('Bàn Trống');

            selectedTableId = null;
            $("#invoiceContainer").html('');
        });
    });
</script>

<style>
    .order-container {
        display: flex;
        gap: 20px;
    }

    .left-panel, .right-panel {
        flex: 1;
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #fff;
    }

    .actions {
        margin-top: 15px;
        display: flex;
        gap: 10px;
    }

    .btn-add-table, .btn-remove-table {
        flex: 1;
        padding: 8px;
        background: #d32f2f;
        color: #fff;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

    .bill-section {
        margin-top: 30px;
    }

    .total-payment {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 15px;
    }

        .total-payment input {
            width: 150px;
            padding: 5px;
            text-align: right;
        }

    .btn-pay {
        width: 100%;
        padding: 10px;
        background: #b71c1c;
        color: #fff;
        border: none;
        border-radius: 5px;
        margin-top: 10px;
        cursor: pointer;
    }

    .table-item.empty-table {
        background-color: #e0f7fa;
        border: 1px solid #00acc1;
    }

    .table-item.has-customer {
        background-color: #ffcdd2;
        border: 1px solid #e53935;
    }
</style>