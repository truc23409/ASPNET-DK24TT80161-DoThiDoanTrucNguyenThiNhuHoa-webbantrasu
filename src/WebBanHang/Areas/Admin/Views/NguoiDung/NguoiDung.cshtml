@model List<WebBanHang.Models.User>

@{
    Layout = "../Shared/_Layout.cshtml";
    ViewBag.Title = "Danh sách người dùng";
}

<link href="~/Content/SanPhamAdmin.css" rel="stylesheet" />
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- DataTables JS -->
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

<div class="page-container">
    <div class="category-header">
        <h2 class="category-title">Danh sách người dùng</h2>
    </div>

    <div class="top-actions">
        <div class="search-container">
            <input type="text" id="searchBox" placeholder="Search" onkeyup="searchUser()">
            <button class="search-btn">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>

    <!-- Phần điều khiển phân trang -->
    <div id="customControls" style="display: flex; align-items: center; gap: 10px;">
        <div id="dataTables_length"></div> <!-- DataTables render "Show entries" -->
    </div>

    @if (Model == null || !Model.Any())
    {
        <p class="alert alert-warning">Không có người dùng nào.</p>
    }
    else
    {
        <table class="category-table" id="userTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Địa chỉ</th>
                    <th>Vai trò</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Username</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.Phone</td>
                        <td>@user.Address</td>
                        <td>@user.Role</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
    $(document).ready(function () {
        // Khởi tạo DataTables
        var table = $('#userTable').DataTable({
            "paging": true,
            "lengthMenu": [5, 10, 25, 50],
            "pageLength": 10,
            "ordering": true,
            "info": true,
            "searching": false, // Tắt tìm kiếm mặc định của DataTables để dùng tìm kiếm tùy chỉnh
            "destroy": true,  // Tránh lỗi DataTable bị khởi tạo lại
            "columnDefs": [
                { "orderable": false, "targets": [0, 1, 3, 4, 5, 6] }, // Chỉ cho phép sắp xếp cột "Họ và tên" (index 2)
            ],
            "language": {
                "lengthMenu": "Show _MENU_ ",
                "zeroRecords": "Không tìm thấy người dùng nào",
                "info": "Hiển thị _START_ đến _END_ trong tổng số _TOTAL_ người dùng",
                "infoEmpty": "Không có dữ liệu để hiển thị",
                "infoFiltered": "(lọc từ _MAX_ người dùng)",
                "paginate": {
                    "first": "Đầu",
                    "last": "Cuối",
                    "next": "Tiếp",
                    "previous": "Trước"
                }
            },
            "drawCallback": function () {
                $("#userTable_length").appendTo("#dataTables_length"); // Di chuyển phần "Show entries"
            }
        });
    });

    // Tìm kiếm trong bảng
    function searchUser() {
        var input, filter, table, tr, tdArray, i, txtValue, foundCount = 0;
        input = document.getElementById("searchBox");
        filter = input.value.toUpperCase();
        table = document.getElementById("userTable");
        tr = table.getElementsByTagName("tr");

        for (i = 1; i < tr.length; i++) {
            tdArray = tr[i].getElementsByTagName("td");
            let found = false;
            for (let td of tdArray) {
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        found = true;
                        break;
                    }
                }
            }
            tr[i].style.display = found ? "" : "none";
            if (found) foundCount++;
        }

        // Hiển thị thông báo nếu không tìm thấy kết quả
        let alertBox = document.getElementById("noResultAlert");
        if (!foundCount) {
            if (!alertBox) {
                let newAlert = document.createElement("p");
                newAlert.id = "noResultAlert";
                newAlert.className = "alert alert-warning";
                newAlert.innerText = "Không tìm thấy kết quả.";
                table.parentNode.insertBefore(newAlert, table);
            }
        } else {
            if (alertBox) alertBox.remove();
        }
    }
</script>

<style>
    .dataTables_wrapper th,
    .dataTables_wrapper td {
        border: 1px solid #ddd !important;
    }

    table {
        width: 100%;
        table-layout: auto; /* Thay fixed thành auto */
        border-collapse: collapse;
        border: none !important;
    }
    th, td {
        border: 1px solid #ddd; /* Đổi màu đường kẻ thành xám nhạt */
        padding: 8px;
        text-align: left;
    }

    tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    tr:nth-child(odd) {
        background-color: white;
    }

    .category-header {
        background-color: #ffff;
        padding: 20px 30px;
        border-radius: 0 25px 25px 0;
        margin-bottom: 20px;
    }

    .category-title {
        font-size: 24px;
        font-weight: bold;
        margin: 0;
    }

    .top-actions {
        display: flex;
        justify-content: flex-end; /* Chỉ giữ tìm kiếm bên phải */
        align-items: center;
        margin-bottom: 15px;
    }

    .search-container {
        position: relative;
        width: 250px;
    }

        .search-container input {
            width: 100%;
            padding: 8px 35px 8px 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            outline: none;
        }

    .search-btn {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        background-color: transparent;
        border: none;
        cursor: pointer;
        color: #007bff;
        font-size: 16px;
    }

    .category-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        background: white;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        overflow: hidden;
    }

        .category-table th, .category-table td {
            padding: 12px;
            border: 1px solid #ddd;
            text-align: center;
        }

        .category-table th {
            background-color: #f8f9fa;
            font-weight: bold;
        }

        .category-table tr:hover {
            background-color: #f1f1f1;
            transition: background-color 0.3s ease-in-out;
        }

    .alert {
        padding: 12px;
        text-align: center;
        border-radius: 5px;
        font-weight: bold;
        margin-bottom: 15px;
    }

    /* Style cho phần điều khiển phân trang */
    #customControls {
        display: flex;
        align-items: center;
        margin-bottom: 5px;
        gap: 10px; /* Khoảng cách giữa các phần tử */
    }

    #dataTables_length select {
        height: 40px; /* Đặt cùng chiều cao với nút Sort */
        padding: 8px 16px;
        font-size: 16px;
        border-radius: 8px;
        border: 1px solid #ccc;
        background-color: white;
        cursor: pointer;
    }

    /* Ẩn mũi tên sort trên tiêu đề bảng */
    .dataTables_wrapper th {
        pointer-events: none; /* Không cho click vào cột */
    }

        .dataTables_wrapper th::after,
        .dataTables_wrapper th::before {
            display: none !important; /* Ẩn mũi tên */
        }
</style>