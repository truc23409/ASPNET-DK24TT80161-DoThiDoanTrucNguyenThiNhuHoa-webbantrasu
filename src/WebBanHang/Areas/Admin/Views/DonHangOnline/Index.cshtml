@{
    Layout = "../Shared/_Layout.cshtml";
}

<meta charset="utf-8">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

<!-- DataTables JS -->
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

<div class="page-container">
    <div class="order-container">
        <!-- Recent Orders -->
        <section class="recent-orders container mt-4">
            <div class="category-header">
                <h3 class="category-title text-center">Đơn hàng Online</h3>
            </div>

            <div class="top-actions">
                <div class="search-container">
                    <input type="text" id="searchBox" placeholder="Tìm kiếm đơn hàng" onkeyup="searchOrder()">
                    <button class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>

            <div id="customControls" style="display: flex; align-items: center; gap: 10px;">
                <div id="dataTables_length"></div>
                <button id="sortButton" type="button" class="btn btn-primary">
                    <svg id="sortIcon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                        <path d="M7 10l5-5 5 5H7zm0 4h10l-5 5-5-5z" />
                    </svg>
                    Sort
                </button>
            </div>

            <table class="table table-bordered table-striped" id="orderTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Người dùng</th>
                        <th>Trạng thái</th>
                        <th>Cập nhật trạng thái</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.AllOrders is System.Collections.Generic.List<WebBanHang.Models.RecentOrderModel> allOrdersList && allOrdersList.Any())
                    {
                        var orders = ViewBag.AllOrders as System.Collections.Generic.List<WebBanHang.Models.RecentOrderModel>;
                        foreach (var order in orders)
                        {
                            <tr>
                                <td>@order.OrderId</td>
                                <td>@order.FullName</td>
                                <td>@order.Status</td>
                                <td>
                                    <select class="status-select" data-order-id="@order.OrderId">
                                        @foreach (var status in ViewBag.OrderStatuses as System.Collections.Generic.List<WebBanHang.Models.OrderStatu>)
                                        {
                                            if (status.StatusId == order.StatusId)
                                            {
                                                <option value="@status.StatusId" selected>@status.StatusName</option>
                                            }
                                            else
                                            {
                                                <option value="@status.StatusId">@status.StatusName</option>
                                            }
                                        }
                                    </select>
                                    <button class="btn-update-status" data-order-id="@order.OrderId">Cập nhật</button>
                                </td>
                                <td>@(order.OrderDate != default(DateTime) ? order.OrderDate.ToString("dd/MM/yyyy HH:mm") : "Chưa xác định")</td>
                                <td>@(order.TotalAmount >= 0 ? order.TotalAmount.ToString("N0") + "đ" : "Chưa xác định")</td>
                                <td>
                                    <button class="btn-view-detail" data-order-id="@order.OrderId" data-toggle="modal" data-target="#orderDetailModal">
                                        <i class="fas fa-eye"></i> Xem
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </div>
</div>

<!-- Modal Chi tiết đơn hàng -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" role="dialog" aria-labelledby="orderDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderDetailModalLabel">Chi tiết đơn hàng</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="orderDetailContent">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="sr-only">Loading...</span>
                        </div>
                        <p>Đang tải dữ liệu...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var table = $('#orderTable').DataTable({
            "paging": true,
            "lengthMenu": [5, 10, 25, 50],
            "pageLength": 10,
            "ordering": true,
            "info": true,
            "searching": false,
            "destroy": true,
            "columnDefs": [
                { "orderable": false, "targets": [3, 5, 6] }
            ],
            "language": {
                "lengthMenu": "Show _MENU_ ",
                "zeroRecords": "Không tìm thấy đơn hàng nào",
                "info": "Show _START_ đến _END_ trong tổng số _TOTAL_ ",
                "infoEmpty": "Không có dữ liệu để Show",
                "infoFiltered": "(lọc từ _MAX_ )",
                "paginate": {
                    "first": "Đầu",
                    "last": "Cuối",
                    "next": "Tiếp",
                    "previous": "Trước"
                }
            },
            "drawCallback": function () {
                $("#orderTable_length").appendTo("#dataTables_length");
            }
        });

        var sortDirection = 'asc';

        $("#sortButton").on("click", function () {
            let icon = $("#sortIcon");
            table.order([1, sortDirection]).draw();
            sortDirection = (sortDirection === 'asc') ? 'desc' : 'asc';
            icon.html(sortDirection === "asc"
                ? '<path d="M7 10l5-5 5 5H7zm0 4h10l-5 5-5-5z"/>'
                : '<path d="M7 14l5 5 5-5H7zm0-4h10l-5-5-5 5z"/>'
            );
        });

        // Cập nhật trạng thái đơn hàng
        $(document).on('click', '.btn-update-status', function () {
            var orderId = $(this).data('order-id');
            var statusId = $(this).siblings('.status-select').val();

            $.ajax({
                url: '@Url.Action("UpdateOrderStatus", "DonHangOnline", new { area = "Admin" })',
                type: 'POST',
                data: { orderId: orderId, statusId: statusId },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: res.message,
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => {
                            var row = $('button[data-order-id="' + orderId + '"]').closest('tr');
                            row.find('td:nth-child(3)').text(res.newStatus);
                        });
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Đã có lỗi xảy ra khi cập nhật trạng thái!', 'error');
                }
            });
        });

        // Xem chi tiết đơn hàng
        $(document).on('click', '.btn-view-detail', function () {
            var orderId = $(this).data('order-id');

            $('#orderDetailContent').html(`
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p>Đang tải dữ liệu...</p>
                </div>
            `);

            $.ajax({
                url: '@Url.Action("GetOrderDetail", "DonHangOnline", new { area = "Admin" })',
                type: 'GET',
                data: { orderId: orderId },
                success: function (response) {
                    if (response.success) {
                        var html = generateOrderDetailHTML(response.data);
                        $('#orderDetailContent').html(html);
                    } else {
                        $('#orderDetailContent').html(`
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle"></i> ${response.message}
                            </div>
                        `);
                    }
                },
                error: function () {
                    $('#orderDetailContent').html(`
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> Đã xảy ra lỗi khi tải chi tiết đơn hàng!
                        </div>
                    `);
                }
            });
        });
    });

    function generateOrderDetailHTML(order) {
        var html = `
            <div class="order-info">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong><i class="fas fa-receipt"></i> Mã đơn hàng:</strong> #${order.OrderId}</p>
                        <p><strong><i class="fas fa-user"></i> Người đặt:</strong> ${order.FullName}</p>
                        <p><strong><i class="fas fa-phone"></i> Số điện thoại:</strong> ${order.Phone || 'Chưa cập nhật'}</p>
                        <p><strong><i class="fas fa-envelope"></i> Email:</strong> ${order.Email || 'Chưa cập nhật'}</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong><i class="fas fa-calendar"></i> Ngày đặt:</strong> ${order.OrderDate}</p>
                        <p><strong><i class="fas fa-money-bill-wave"></i> Tổng tiền:</strong> <span class="text-danger font-weight-bold">${formatCurrency(order.TotalAmountValue)}</span></p>
                        <p><strong><i class="fas fa-credit-card"></i> Phương thức thanh toán:</strong> ${order.PaymentMethod}</p>
                        <p><strong><i class="fas fa-truck"></i> Trạng thái:</strong>
                            <span class="badge badge-${getStatusBadgeClass(order.Status)}">${order.Status}</span>
                        </p>
                    </div>
                </div>
                ${order.DeliveryAddress ? `
                <div class="row mt-2">
                    <div class="col-12">
                        <p><strong><i class="fas fa-map-marker-alt"></i> Địa chỉ giao hàng:</strong> ${order.DeliveryAddress}</p>
                    </div>
                </div>
                ` : ''}
            </div>
            <hr>
            <h5><i class="fas fa-shopping-cart"></i> Danh sách sản phẩm</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead class="thead-light">
                        <tr>
                            <th>STT</th>
                            <th>Tên sản phẩm</th>
                            <th>Size</th>
                            <th>Topping</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        if (order.OrderDetails && order.OrderDetails.length > 0) {
            var stt = 1;
            order.OrderDetails.forEach(function(item) {
                html += `
                    <tr>
                        <td>${stt++}</td>
                        <td>${item.FoodName}</td>
                        <td>${item.SizeName || 'Không có'}</td>
                        <td>${item.ToppingName || 'Không có'}</td>
                        <td>${item.Quantity}</td>
                        <td>${formatCurrency(item.Price)}</td>
                        <td>${formatCurrency(item.Quantity * item.Price)}</td>
                    </tr>
                `;
            });
        } else {
            html += `
                <tr>
                    <td colspan="7" class="text-center">Không có sản phẩm nào</td>
                </tr>
            `;
        }

        html += `
                    </tbody>
                    <tfoot>
                        <tr class="table-info">
                            <td colspan="6" class="text-right font-weight-bold">Tổng cộng:</td>
                            <td class="font-weight-bold text-danger">${formatCurrency(order.TotalAmountValue)}</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        `;

        return html;
    }

    function formatCurrency(amount) {
        if (!amount) return '0₫';
        return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
    }

    function getStatusBadgeClass(status) {
        var statusMap = {
            'Đặt hàng thành công': 'info',
            'Đang chuẩn bị đơn hàng': 'warning',
            'Đang giao hàng': 'primary',
            'Giao hàng thành công': 'success',
            'Đã hủy': 'danger'
        };
        return statusMap[status] || 'secondary';
    }

    function searchOrder() {
        var input, filter, table, tr, tdArray, i, txtValue, foundCount = 0;
        input = document.getElementById("searchBox");
        filter = input.value.toUpperCase();
        table = document.getElementById("orderTable");
        tr = table.getElementsByTagName("tr");

        for (i = 1; i < tr.length; i++) {
            tdArray = tr[i].getElementsByTagName("td");
            let found = false;
            for (let td of tdArray) {
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        found = true;
                        break;
                    }
                }
            }
            tr[i].style.display = found ? "" : "none";
            if (found) foundCount++;
        }

        let alertBox = document.getElementById("noResultAlert");
        if (!foundCount) {
            if (!alertBox) {
                let newAlert = document.createElement("p");
                newAlert.id = "noResultAlert";
                newAlert.className = "alert alert-warning";
                newAlert.innerText = "Không tìm thấy kết quả.";
                table.parentNode.insertBefore(newAlert, table);
            }
        } else {
            if (alertBox) alertBox.remove();
        }
    }
</script>

<style>
    .order-container {
        display: flex;
        gap: 20px;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: center;
        vertical-align: middle !important;
    }

    th {
        background-color: #f8f9fa;
        font-weight: bold;
    }

    tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    tr:nth-child(odd) {
        background-color: white;
    }

    .status-select {
        margin-right: 10px;
        padding: 5px;
    }

    .btn-update-status {
        padding: 5px 10px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

        .btn-update-status:hover {
            background-color: #0056b3;
        }

    .btn-view-detail {
        background-color: #17a2b8;
        color: white;
        border: none;
        border-radius: 5px;
        padding: 5px 10px;
        cursor: pointer;
        transition: background-color 0.3s;
    }

        .btn-view-detail:hover {
            background-color: #138496;
        }

        .btn-view-detail i {
            margin-right: 5px;
        }

    .top-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .search-container {
        position: relative;
        width: 250px;
    }

        .search-container input {
            width: 100%;
            padding: 8px 35px 8px 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            outline: none;
        }

    .search-btn {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        background-color: transparent;
        border: none;
        cursor: pointer;
        color: #007bff;
        font-size: 16px;
    }

    #customControls {
        display: flex;
        align-items: center;
        margin-bottom: 5px;
        gap: 10px;
    }

    #dataTables_length select {
        height: 40px;
        padding: 8px 16px;
        font-size: 16px;
        border-radius: 8px;
        border: 1px solid #ccc;
        background-color: white;
        cursor: pointer;
    }

    #sortButton {
        display: flex;
        align-items: center;
        gap: 8px;
        background-color: #f3e8ff;
        color: #7c3aed;
        font-weight: bold;
        padding: 8px 16px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: background 0.3s;
        height: 40px;
    }

        #sortButton:hover {
            background-color: #e9d5ff;
        }

    #sortIcon {
        width: 16px;
        height: 16px;
    }

    .dataTables_wrapper th {
        pointer-events: none;
    }

        .dataTables_wrapper th::after,
        .dataTables_wrapper th::before {
            display: none !important;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        border: none;
    }

    .dataTables_wrapper table {
        border: none !important;
    }

    .category-header {
        background-color: #ffff;
        padding: 20px 30px;
        border-radius: 0 25px 25px 0;
        margin-bottom: 20px;
    }

    .category-title {
        font-size: 24px;
        font-weight: bold;
        margin: 0;
    }

    .order-info {
        margin-bottom: 20px;
    }

        .order-info p {
            margin-bottom: 8px;
        }

    .modal-lg {
        max-width: 900px;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
    }

    .badge-info {
        background-color: #17a2b8;
        color: white;
    }

    .badge-warning {
        background-color: #ffc107;
        color: #212529;
    }

    .badge-primary {
        background-color: #007bff;
        color: white;
    }

    .badge-success {
        background-color: #28a745;
        color: white;
    }

    .badge-danger {
        background-color: #dc3545;
        color: white;
    }

    .badge-secondary {
        background-color: #6c757d;
        color: white;
    }

    .table-info {
        background-color: #d1ecf1 !important;
    }

    hr {
        margin: 15px 0;
    }
</style>