@model WebBanHang.Models.Ingredient

@{
    ViewBag.Title = "Xác nhận xóa nguyên liệu";
}

<h2 class="text-danger text-center">Xác nhận xóa nguyên liệu</h2>

<div class="container border p-4 rounded shadow-lg" style="max-width: 500px; background-color: #f8f9fa;">
    <h3 class="text-center text-primary">@Model.IngredientName</h3>

    <p><strong>ID nguyên liệu:</strong> @Model.IngredientId</p>
    <p><strong>Số lượng:</strong> @Model.SoLuong</p>

    <p><strong>Hình ảnh:</strong></p>
    <div class="text-center">
        @if (!string.IsNullOrEmpty(Model.ImageURL))
        {
            <img src="@Model.ImageURL" class="img-fluid rounded" style="max-width: 150px; border: 1px solid #ddd; padding: 5px;" />
        }
        else
        {
            <p class="text-muted">Không có hình ảnh</p>
        }
    </div>

    <p class="mt-3"><strong>Last Updated:</strong> @Model.LastUpdated.ToString("yyyy-MM-dd")</p>

    <div class="text-center mt-4">
        @using (Html.BeginForm("Delete", "KhoAdmin", new { area = "Admin" }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.IngredientId) <!-- Giữ lại ID để xử lý xóa -->

            <button type="submit" class="btn btn-danger me-2">Xác nhận xóa</button>
            <a href="@Url.Action("KhoAdmin", "KhoAdmin")" class="btn btn-secondary">Hủy</a>
        }
    </div>
</div>
